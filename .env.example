# ==============================================================================
# .env.example — Environment Variables Template
# ==============================================================================
# INSTRUCTIONS FOR TEAMMATES:
# 1. Copy this file and rename it to  .env  (remove the .example)
# 2. Fill in YOUR OWN API keys below (never share or commit your real .env file)
# 3. The project will NOT work without at least GEMINI_API_KEY and SENDGRID_API_KEY
# ==============================================================================

# ---- AI Provider ----
# Choose which AI to use: "gemini" (recommended) or "groq"
AI_PROVIDER=gemini

# ---- Gemini API Key (PRIMARY — required) ----
# Get your FREE key at: https://aistudio.google.com/app/apikey
# Free tier: 1,500 requests/day — more than enough for demo/dev
GEMINI_API_KEY=YOUR_GEMINI_API_KEY_HERE
GEMINI_MODEL=gemini-2.0-flash

# ---- Groq API Key (OPTIONAL — fallback AI provider) ----
# Get your FREE key at: https://console.groq.com/keys
# Only needed if you set AI_PROVIDER=groq above
GROQ_API_KEY=YOUR_GROQ_API_KEY_HERE
GROQ_MODEL=llama-3.3-70b-versatile

# ---- Live Dataset Configuration ----
DATASET_SIZE=1000
FETCH_BATCH_SIZE=100
DATASET_REFRESH_INTERVAL=5

# ---- AI Generation Settings ----
MAX_OUTPUT_TOKENS=2048
TEMPERATURE=0.7
JSON_RETRY_LIMIT=3
DEFAULT_VARIANT_COUNT=3

# ---- SendGrid Email Configuration ----
# EMAIL_STUB_MODE controls whether emails are ACTUALLY sent or just simulated:
#   true  = STUB MODE  → Emails are NOT sent. Just logged. Safe for testing.
#   false = LIVE MODE  → Emails ARE sent for real via SendGrid.
#
# Keep EMAIL_STUB_MODE=true until your SendGrid is fully set up.
# Once ready, set EMAIL_STUB_MODE=false and add your SendGrid key below.
EMAIL_STUB_MODE=true

EMAIL_SERVICE=sendgrid

# Get your FREE SendGrid API key at: https://sendgrid.com
# Step 1: Register at sendgrid.com (free plan = 100 emails/day forever)
# Step 2: Go to Settings > API Keys > Create API Key (Full Access)
# Step 3: Go to Settings > Sender Authentication > Verify a Single Sender
#         (verify the email address you put in FROM_EMAIL below)
# Step 4: Paste your API key here
SENDGRID_API_KEY=YOUR_SENDGRID_API_KEY_HERE

# This must be the SAME email you verified as a Single Sender in SendGrid
FROM_EMAIL=your-verified-email@gmail.com
FROM_NAME=Gemini Email AI

# ---- Server Configuration ----
SERVER_HOST=0.0.0.0
SERVER_PORT=8000
